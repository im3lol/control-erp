// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// SETTINGS MODULE
// ============================================

model Company {
  id             String   @id @default(cuid())
  nameAr         String   @default("شركتي")
  nameEn         String   @default("My Company")
  address        String?
  phone          String?
  email          String?
  taxNumber      String?
  logo           String?
  baseCurrencyId String?
  fiscalYearStart String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Currency {
  id           String   @id @default(cuid())
  code         String   @unique
  nameAr       String
  nameEn       String
  symbol       String
  isBase       Boolean  @default(false)
  exchangeRate Float    @default(1.0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UnitOfMeasure {
  id        String   @id @default(cuid())
  code      String   @unique
  nameAr    String
  nameEn    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items Item[]
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String
  email     String?
  password  String
  role      String   @default("viewer")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// INVENTORY MODULE
// ============================================

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  nameAr    String
  nameEn    String?
  location  String?
  manager   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockMovements   StockMovement[]
  itemBalances     ItemBalance[]
  fifoLayers       FifoLayer[]
  purchaseInvoices PurchaseInvoice[]
}

model ItemCategory {
  id        String   @id @default(cuid())
  code      String   @unique
  nameAr    String
  nameEn    String?
  parentId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   ItemCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ItemCategory[] @relation("CategoryHierarchy")
  items    Item[]
}

model Item {
  id          String   @id @default(cuid())
  code        String   @unique
  nameAr      String
  nameEn      String?
  categoryId  String?
  uomId       String?
  costMethod  String   @default("FIFO")
  sellPrice   Float    @default(0)
  minStock    Float    @default(0)
  maxStock    Float?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category       ItemCategory?    @relation(fields: [categoryId], references: [id])
  uom            UnitOfMeasure?   @relation(fields: [uomId], references: [id])
  balances       ItemBalance[]
  fifoLayers     FifoLayer[]
  stockMovements StockMovement[]
  salesLines     SalesInvoiceLine[]
  purchaseLines  PurchaseInvoiceLine[]
}

model ItemBalance {
  id          String   @id @default(cuid())
  itemId      String
  warehouseId String
  quantity    Float    @default(0)
  avgCost     Float    @default(0)
  updatedAt   DateTime @updatedAt

  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([itemId, warehouseId])
}

model FifoLayer {
  id                String   @id @default(cuid())
  itemId            String
  warehouseId       String
  quantity          Float
  remaining         Float
  unitCost          Float
  purchaseInvoiceId String?
  date              DateTime
  createdAt         DateTime @default(now())

  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
}

model StockMovement {
  id            String   @id @default(cuid())
  number        String   @unique
  type          String
  itemId        String
  warehouseId   String
  quantity      Float
  unitCost      Float    @default(0)
  totalCost     Float    @default(0)
  referenceType String?
  referenceId   String?
  reason        String?
  date          DateTime
  createdAt     DateTime @default(now())

  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
}

// ============================================
// ACCOUNTING MODULE
// ============================================

model Account {
  id        String   @id @default(cuid())
  code      String   @unique
  nameAr    String
  nameEn    String?
  type      String
  parentId  String?
  isLeaf    Boolean  @default(true)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent     Account?           @relation("AccountHierarchy", fields: [parentId], references: [id])
  children   Account[]          @relation("AccountHierarchy")
  entryLines JournalEntryLine[]
}

model JournalEntry {
  id           String   @id @default(cuid())
  number       String   @unique
  date         DateTime
  description  String?
  status       String   @default("DRAFT")
  sourceType   String?
  sourceId     String?
  reversedById String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lines      JournalEntryLine[]
  reversedBy JournalEntry?  @relation("JournalReversal", fields: [reversedById], references: [id])
  reversalOf JournalEntry[] @relation("JournalReversal")
}

model JournalEntryLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Float    @default(0)
  credit         Float    @default(0)
  description    String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])
}

// ============================================
// SALES MODULE
// ============================================

model Customer {
  id           String   @id @default(cuid())
  code         String   @unique
  nameAr       String
  nameEn       String?
  phone        String?
  email        String?
  address      String?
  balance      Float    @default(0)
  creditLimit  Float    @default(0)
  paymentTerms Int      @default(30)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salesInvoices   SalesInvoice[]
  receiptVouchers ReceiptVoucher[]
}

model SalesInvoice {
  id              String   @id @default(cuid())
  number          String   @unique
  customerId      String
  date            DateTime
  dueDate         DateTime?
  status          String   @default("DRAFT")
  subtotal        Float    @default(0)
  discountAmount  Float    @default(0)
  discountPercent Float    @default(0)
  taxAmount       Float    @default(0)
  taxPercent      Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  balanceDue      Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer     Customer            @relation(fields: [customerId], references: [id])
  lines        SalesInvoiceLine[]
  receiptLines ReceiptLine[]
}

model SalesInvoiceLine {
  id             String   @id @default(cuid())
  salesInvoiceId String
  itemId         String
  quantity       Float
  unitPrice      Float
  discountAmount Float    @default(0)
  taxAmount      Float    @default(0)
  totalAmount    Float
  costAmount     Float    @default(0)

  salesInvoice SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id])
}

model ReceiptVoucher {
  id            String   @id @default(cuid())
  number        String   @unique
  customerId    String
  date          DateTime
  amount        Float
  paymentMethod String   @default("CASH")
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer     @relation(fields: [customerId], references: [id])
  lines    ReceiptLine[]
}

model ReceiptLine {
  id               String   @id @default(cuid())
  receiptVoucherId String
  salesInvoiceId   String
  amount           Float

  receiptVoucher ReceiptVoucher @relation(fields: [receiptVoucherId], references: [id], onDelete: Cascade)
  salesInvoice   SalesInvoice   @relation(fields: [salesInvoiceId], references: [id])
}

// ============================================
// PURCHASES MODULE
// ============================================

model Supplier {
  id           String   @id @default(cuid())
  code         String   @unique
  nameAr       String
  nameEn       String?
  phone        String?
  email        String?
  address      String?
  balance      Float    @default(0)
  paymentTerms Int      @default(30)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchaseInvoices PurchaseInvoice[]
  paymentVouchers  PaymentVoucher[]
}

model PurchaseInvoice {
  id              String   @id @default(cuid())
  number          String   @unique
  supplierId      String
  warehouseId     String
  date            DateTime
  dueDate         DateTime?
  status          String   @default("DRAFT")
  subtotal        Float    @default(0)
  discountAmount  Float    @default(0)
  discountPercent Float    @default(0)
  taxAmount       Float    @default(0)
  taxPercent      Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  balanceDue      Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  supplier      Supplier             @relation(fields: [supplierId], references: [id])
  warehouse     Warehouse            @relation(fields: [warehouseId], references: [id])
  lines         PurchaseInvoiceLine[]
  paymentLines  PaymentLine[]
}

model PurchaseInvoiceLine {
  id                String   @id @default(cuid())
  purchaseInvoiceId String
  itemId            String
  quantity          Float
  unitPrice         Float
  discountAmount    Float    @default(0)
  taxAmount         Float    @default(0)
  totalAmount       Float

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId], references: [id])
}

model PaymentVoucher {
  id            String   @id @default(cuid())
  number        String   @unique
  supplierId    String
  date          DateTime
  amount        Float
  paymentMethod String   @default("CASH")
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  supplier Supplier     @relation(fields: [supplierId], references: [id])
  lines    PaymentLine[]
}

model PaymentLine {
  id                String   @id @default(cuid())
  paymentVoucherId  String
  purchaseInvoiceId String
  amount            Float

  paymentVoucher  PaymentVoucher  @relation(fields: [paymentVoucherId], references: [id], onDelete: Cascade)
  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id])
}
